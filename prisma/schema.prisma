generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Empresas ─────────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  razonSocial String?
  cuit        String?
  address     String?
  phone       String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices        Invoice[]
  taxEntries      TaxEntry[]
  serviceInvoices ServiceInvoice[]
  partSales       PartSale[]

  @@map("companies")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ClientType {
  FISICA
  JURIDICA
}

enum Role {
  vendedor
  admin
  gerente
}

enum VehicleStatus {
  available
  reserved
  sold
}

enum SaleStatus {
  active
  cancelled
  completed
}

enum TaxType {
  IVA
  IIBB
  TEM
}

enum TaxEntryKind {
  debito   // genera obligación
  credito  // reduce obligación (facturas recibidas, pagos, retenciones)
}

enum SaleStepStatus {
  pending
  completed
}

enum PaymentType {
  cash
  transfer
  check
  used_vehicle
  retencion
}

enum CheckStatus {
  pending
  deposited
  cleared
  bounced
  cancelled
}

enum DocType {
  dni_front
  dni_back
  cuit
  form_08
  payment_proof
  contract
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  INVOICED
  RECEIVED
  PAID
}

enum StockMovementType {
  PURCHASE
  SERVICE_OUT
  SALE_OUT
  ADJUSTMENT
}

enum ServiceOrderStatus {
  PENDING           // ficha creada, turno pendiente
  APPOINTMENT_SET   // turno agendado
  IN_TRANSIT        // traslado al taller registrado
  AT_WORKSHOP       // recibido en taller, MO generada
  COMPLETED         // trabajo terminado por el taller
  CLOSED            // retirado por cliente, ficha cerrada
  CANCELLED
}

enum ServiceInvoiceStatus {
  PENDING
  PAID
}

enum PartSaleStatus {
  PENDING
  PAID
  CANCELLED
}

// ─── Auth (NextAuth / Auth.js) ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(vendedor)
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]

  sales             Sale[]          @relation("VendorSales")
  saleSteps         SaleStep[]      @relation("CompletedBy")
  auditLogs         AuditLog[]
  receivedDocuments Document[]      @relation("DocumentReceived")
  taxEntries        TaxEntry[]      @relation("TaxEntries")
  stockMovements    StockMovement[] @relation("StockMovements")
  partSales         PartSale[]      @relation("PartSaleCreatedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Domain ───────────────────────────────────────────────────────────────────

model Client {
  id                  String     @id @default(cuid())
  clientType          ClientType @default(FISICA)
  // FISICA: nombre y apellido / JURIDICA: razón social
  name                String
  // FISICA only
  dni                 String?    @unique
  ivaCondition        String?
  maritalStatus       String?
  profession          String?
  // JURIDICA only
  legalRepresentative String?
  // Shared
  // Partial unique index added in migration: CREATE UNIQUE INDEX ON clients(cuit) WHERE cuit IS NOT NULL
  cuit                String?
  address             String?
  postalCode          String?
  city                String?
  province            String?
  phone               String?
  email               String?
  createdAt           DateTime   @default(now())

  sales         Sale[]
  serviceOrders ServiceOrder[]
  partSales     PartSale[]

  @@map("clients")
}

model Vehicle {
  id        String        @id @default(cuid())
  brand     String
  model     String
  year      Int
  color     String?
  vin          String?  @unique  // nullable: por pedido no tiene VIN hasta que llega
  dominio      String?          // patente/dominio asignado al patentar
  motorNumber  String?          // número de motor
  price        Decimal  @db.Decimal(12, 2)
  status    VehicleStatus @default(available)
  isPedido  Boolean       @default(false)  // true = venta por pedido a fábrica
  isUsado   Boolean       @default(false)  // true = auto usado recibido como parte de pago
  location  String?                        // cochera / espacio donde está estacionado
  mileage   Int?                           // kilometraje (solo usados)
  createdAt DateTime      @default(now())

  sales           Sale[]
  tradeInPayments Payment[]      @relation("TradeIn")
  serviceOrders   ServiceOrder[]

  @@map("vehicles")
}

model Sale {
  id                String     @id @default(cuid())
  vendorId          String
  clientId          String?
  vehicleId         String
  version           Int        @default(1)
  status            SaleStatus @default(active)
  salePrice         Decimal?   @db.Decimal(12, 2)
  lastStepUpdatedAt DateTime?
  cancelReason      String?
  cancelledAt       DateTime?
  createdAt         DateTime   @default(now())

  vendor    User      @relation("VendorSales", fields: [vendorId], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id])
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  saleSteps       SaleStep[]
  payments        Payment[]
  documents       Document[]
  invoice         Invoice?
  patentamiento   Patentamiento?
  patenteOtorgada PatenteOtorgada?
  entrega         Entrega?

  @@map("sales")
}

model SaleStep {
  id          String         @id @default(cuid())
  saleId      String
  stepNumber  Int
  status      SaleStepStatus @default(pending)
  completedBy String?
  completedAt DateTime?
  notes       String?

  sale            Sale  @relation(fields: [saleId], references: [id])
  completedByUser User? @relation("CompletedBy", fields: [completedBy], references: [id])

  @@unique([saleId, stepNumber])
  @@map("sale_steps")
}

model Payment {
  id                  String      @id @default(cuid())
  saleId              String
  type                PaymentType
  amount              Decimal     @db.Decimal(12, 2)
  confirmedAt         DateTime?
  tradeInVehicleId    String?
  retentionType       String?
  retentionCertNumber String?
  retentionDate       DateTime?
  createdAt           DateTime    @default(now())

  sale           Sale     @relation(fields: [saleId], references: [id])
  tradeInVehicle Vehicle? @relation("TradeIn", fields: [tradeInVehicleId], references: [id])
  checks         Check[]

  @@map("payments")
}

model Check {
  id         String      @id @default(cuid())
  paymentId  String
  bank       String
  amount     Decimal     @db.Decimal(12, 2)
  dueDate    DateTime
  receivedAt DateTime    @default(now())
  status     CheckStatus @default(pending)
  bouncedAt  DateTime?

  payment Payment @relation(fields: [paymentId], references: [id])

  @@map("checks")
}

model Document {
  id         String    @id @default(cuid())
  saleId     String
  docType    DocType
  fileKey    String?
  receivedBy String?
  receivedAt DateTime?
  uploadedAt DateTime  @default(now())

  sale           Sale  @relation(fields: [saleId], references: [id])
  receivedByUser User? @relation("DocumentReceived", fields: [receivedBy], references: [id])

  @@map("documents")
}

enum InvoiceType {
  A
  B
  C
}

model Invoice {
  id            String      @id @default(cuid())
  saleId        String      @unique
  companyId     String?
  invoiceNumber String
  invoiceDate   DateTime
  invoiceType   InvoiceType
  totalAmount   Decimal     @db.Decimal(12, 2)
  netAmount     Decimal?    @db.Decimal(12, 2)
  vatAmount     Decimal?    @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())

  sale    Sale     @relation(fields: [saleId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@map("invoices")
}

model Patentamiento {
  id               String    @id @default(cuid())
  saleId           String    @unique
  fechaPresentacion DateTime
  seccional        String
  numeroExpediente String?
  observaciones    String?
  createdAt        DateTime  @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("patentamientos")
}

model PatenteOtorgada {
  id                  String   @id @default(cuid())
  saleId              String   @unique
  fechaOtorgamiento   DateTime
  numeroDominio       String
  preEntregaRealizada Boolean  @default(false)
  observaciones       String?
  createdAt           DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("patente_otorgada")
}

model Entrega {
  id              String   @id @default(cuid())
  saleId          String   @unique
  fechaEntrega    DateTime
  receptorNombre  String
  observaciones   String?
  createdAt       DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("entregas")
}

model VehicleModel {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("vehicle_models")
}

model StockLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("stock_locations")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  oldValue   Json?
  newValue   Json?
  userId     String
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model TaxEntry {
  id          String       @id @default(cuid())
  companyId   String?
  taxType     TaxType
  kind        TaxEntryKind
  concept     String
  amount      Decimal      @db.Decimal(12, 2)
  date        DateTime
  createdAt   DateTime     @default(now())
  createdById String

  createdBy User     @relation("TaxEntries", fields: [createdById], references: [id])
  company   Company? @relation(fields: [companyId], references: [id])

  @@map("tax_entries")
}

// ─── Repuestos ────────────────────────────────────────────────────────────────

model PartCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  parts Part[]

  @@map("part_categories")
}

model Part {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  description String?
  categoryId  String
  brand       String?
  unit        String       @default("unidad")
  costPrice   Decimal      @db.Decimal(12, 2)
  salePrice   Decimal      @db.Decimal(12, 2)
  stock       Int          @default(0)
  minStock    Int          @default(0)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  category           PartCategory        @relation(fields: [categoryId], references: [id])
  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  serviceRemitItems  ServiceRemitItem[]
  workOrderItems     WorkOrderItem[]
  saleItems          PartSaleItem[]

  @@map("parts")
}

model StockMovement {
  id          String            @id @default(cuid())
  partId      String
  type        StockMovementType
  quantity    Int
  reference   String?
  notes       String?
  createdById String
  date        DateTime          @default(now())

  part      Part @relation(fields: [partId], references: [id])
  createdBy User @relation("StockMovements", fields: [createdById], references: [id])

  @@map("stock_movements")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  cuit        String?
  address     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  orderNumber String              @unique
  supplierId  String
  status      PurchaseOrderStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  invoice  PurchaseInvoice?
  receipt  GoodsReceipt?
  payment  PurchasePayment?

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  partId          String
  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  part          Part          @relation(fields: [partId], references: [id])

  @@map("purchase_order_items")
}

model PurchaseInvoice {
  id              String      @id @default(cuid())
  purchaseOrderId String      @unique
  invoiceNumber   String
  invoiceDate     DateTime
  invoiceType     InvoiceType @default(B)
  totalAmount     Decimal     @db.Decimal(12, 2)
  netAmount       Decimal?    @db.Decimal(12, 2)
  vatAmount       Decimal?    @db.Decimal(12, 2)
  createdAt       DateTime    @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_invoices")
}

model GoodsReceipt {
  id              String   @id @default(cuid())
  purchaseOrderId String   @unique
  receiptDate     DateTime
  notes           String?
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder    @relation(fields: [purchaseOrderId], references: [id])
  items         GoodsReceiptItem[]

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id             String @id @default(cuid())
  goodsReceiptId String
  partId         String
  orderedQty     Int
  receivedQty    Int

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  part         Part         @relation(fields: [partId], references: [id])

  @@map("goods_receipt_items")
}

model PurchasePayment {
  id              String   @id @default(cuid())
  purchaseOrderId String   @unique
  amount          Decimal  @db.Decimal(12, 2)
  paymentDate     DateTime
  method          String
  reference       String?
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_payments")
}

// ─── Postventa ────────────────────────────────────────────────────────────────

model ServiceOrder {
  id             String             @id @default(cuid())
  // Solicitante (puede o no ser cliente registrado)
  clientId       String?
  clientName     String
  clientPhone    String?
  clientEmail    String?
  // Vehículo (puede o no estar en el sistema)
  vehicleId      String?
  vehicleDominio String
  vehicleDesc    String
  // Motivo
  motivo         String
  notes          String?
  status         ServiceOrderStatus @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  client      Client?  @relation(fields: [clientId], references: [id])
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])

  appointment ServiceAppointment?
  transfer    ServiceTransfer?
  workOrder   WorkOrder?
  pickup      ServicePickup?
  invoice     ServiceInvoice?

  @@map("service_orders")
}

model ServiceAppointment {
  id             String   @id @default(cuid())
  serviceOrderId String   @unique
  scheduledDate  DateTime
  reminderSent   Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@map("service_appointments")
}

model ServiceTransfer {
  id             String   @id @default(cuid())
  serviceOrderId String   @unique
  workshopNumber Int
  driverName     String
  transferDate   DateTime
  notes          String?
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder       @relation(fields: [serviceOrderId], references: [id])
  remitItems   ServiceRemitItem[]

  @@map("service_transfers")
}

model ServiceRemitItem {
  id                String @id @default(cuid())
  serviceTransferId String
  partId            String
  quantity          Int

  serviceTransfer ServiceTransfer @relation(fields: [serviceTransferId], references: [id])
  part            Part            @relation(fields: [partId], references: [id])

  @@map("service_remit_items")
}

model WorkOrder {
  id             String    @id @default(cuid())
  serviceOrderId String    @unique
  moNumber       String    @unique
  description    String
  totalAmount    Decimal   @db.Decimal(12, 2)
  techNotes      String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  serviceOrder ServiceOrder    @relation(fields: [serviceOrderId], references: [id])
  items        WorkOrderItem[]

  @@map("work_orders")
}

model WorkOrderItem {
  id          String  @id @default(cuid())
  workOrderId String
  partId      String?
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  part      Part?     @relation(fields: [partId], references: [id])

  @@map("work_order_items")
}

model ServicePickup {
  id             String   @id @default(cuid())
  serviceOrderId String   @unique
  pickedUpBy     String
  pickupDate     DateTime
  notes          String?
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@map("service_pickups")
}

model ServiceInvoice {
  id             String               @id @default(cuid())
  serviceOrderId String               @unique
  companyId      String               @default("empresa_gsi")
  invoiceType    InvoiceType?
  invoiceNumber  String?
  invoiceDate    DateTime?
  totalAmount    Decimal              @db.Decimal(12, 2)
  netAmount      Decimal?             @db.Decimal(12, 2)
  vatAmount      Decimal?             @db.Decimal(12, 2)
  status         ServiceInvoiceStatus @default(PENDING)
  paymentDate    DateTime?
  paymentMethod  String?
  createdAt      DateTime             @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])

  @@map("service_invoices")
}

// ─── Venta directa de repuestos ──────────────────────────────────────────────

model PartSale {
  id            String        @id @default(cuid())
  saleNumber    String        @unique
  clientId      String?
  clientName    String
  clientPhone   String?
  notes         String?
  totalAmount   Decimal       @db.Decimal(12, 2)
  invoiceType   InvoiceType?
  invoiceNumber String?
  invoiceDate   DateTime?
  netAmount     Decimal?      @db.Decimal(12, 2)
  vatAmount     Decimal?      @db.Decimal(12, 2)
  status        PartSaleStatus @default(PENDING)
  paymentMethod String?
  paymentDate   DateTime?
  companyId     String        @default("empresa_gsi")
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items       PartSaleItem[]
  client      Client?        @relation(fields: [clientId], references: [id])
  company     Company        @relation(fields: [companyId], references: [id])
  createdBy   User           @relation("PartSaleCreatedBy", fields: [createdById], references: [id])

  @@map("part_sales")
}

model PartSaleItem {
  id          String  @id @default(cuid())
  saleId      String
  partId      String
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)

  sale PartSale @relation(fields: [saleId], references: [id])
  part Part     @relation(fields: [partId], references: [id])

  @@map("part_sale_items")
}
