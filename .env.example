# ─── Supabase PostgreSQL ──────────────────────────────────────────────────────
# Connection pooler URL — Project Settings > Database > Connection string > Transaction
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection URL — used by Prisma migrations (prisma.config.ts)
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://gestion.bluemotors.com.ar"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Supabase Storage ────────────────────────────────────────────────────────
# Public URL — Supabase project dashboard > API > Project URL
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# Service role key — Supabase dashboard > API > service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@gestion.bluemotors.com.ar"

# ─── Cron security ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32  — also set in Vercel dashboard
CRON_SECRET=""
